# Conduit CRM — environment template (safe to commit; contains NO secrets)
# Copy to .env.local and fill in real values.

# Neon Postgres — pooled (app runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Neon Postgres — direct/unpooled (drizzle-kit migrations)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

NEXT_PUBLIC_APP_NAME="Conduit"

# --- Auth (Clerk) — when both keys are set, real auth turns on; otherwise dev-auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Optional: register the /api/webhooks/clerk endpoint in Clerk to enable real-time
# user sync (sign-in also JIT-provisions users, so this is not required to launch).
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- AI (Google Gemini — optional; falls back to heuristics without a key) ---
# GEMINI_API_KEY=AIza-xxx           # free-tier key from aistudio.google.com
# AI_MODEL=gemini-2.5-flash
